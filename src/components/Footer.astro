---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy-dark text-gray-400">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6">
          <img src="/images/logo-lp.svg" alt="LP Taxi Heraklion" class="h-12 w-auto" />
        </a>
        <p class="text-sm leading-relaxed mb-6" data-i18n="footer.description">
          Flexible, simple and efficient taxi service in Heraklion, Crete. Enjoy safe luxurious rides with professional drivers.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 bg-white/5 rounded-lg flex items-center justify-center hover:bg-gold/20 hover:text-gold transition-all" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 bg-white/5 rounded-lg flex items-center justify-center hover:bg-gold/20 hover:text-gold transition-all" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 bg-white/5 rounded-lg flex items-center justify-center hover:bg-gold/20 hover:text-gold transition-all" aria-label="TripAdvisor">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 004.04 10.43 5.976 5.976 0 004.075-1.6L12.006 20l1.928-2.387a5.976 5.976 0 004.075 1.6 5.997 5.997 0 004.04-10.43L24 6.648h-4.361a13.573 13.573 0 00-7.633-2.353zM6.003 17.213a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zm11.994 0a3.997 3.997 0 110-7.994 3.997 3.997 0 010 7.994zM6.003 11.219a2.0 2.0 0 100 4.0 2.0 2.0 0 000-4.0zm11.994 0a2.0 2.0 0 100 4.0 2.0 2.0 0 000-4.0z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-6" data-i18n="footer.quickLinks">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="/" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.home">Home</a></li>
          <li><a href="/aboutus" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.about">About Us</a></li>
          <li><a href="/taste-of-heraklion" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.taste">Taste of Heraklion</a></li>
          <li><a href="/crete-cruise" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.cruise">Crete Cruise</a></li>
          <li><a href="/booktaxionline" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.book">Book Online</a></li>
          <li><a href="/tell-us-your-opinion" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.feedback">Tell Us Your Opinion</a></li>
          <li><a href="/privacy-policy" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.privacy">Privacy Policy</a></li>
          <li><a href="/faq" class="hover:text-gold transition-colors text-sm" data-i18n="footer.link.faq">FAQ</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold mb-6" data-i18n="footer.contactUs">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm" data-i18n="footer.location">Heraklion, Crete, Greece</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+306943551122" class="text-sm hover:text-gold transition-colors">+30 694 355 1122</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:lptaxiheraklion@gmail.com" class="text-sm hover:text-gold transition-colors">lptaxiheraklion@gmail.com</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm" data-i18n="footer.available">Available 24/7</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm">&copy; {currentYear} <span data-i18n="footer.copyright">LP Taxi Heraklion. All rights reserved.</span></p>
      <div class="flex gap-6">
        <a href="/privacy-policy" class="text-sm hover:text-gold transition-colors" data-i18n="footer.link.privacy">Privacy Policy</a>
        <a href="/tell-us-your-opinion" class="text-sm hover:text-gold transition-colors" data-i18n="footer.feedback">Feedback</a>
      </div>
    </div>
  </div>
</footer>
