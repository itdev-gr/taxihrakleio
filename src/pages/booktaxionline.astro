---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book Taxi Online | LP Taxi Heraklion">
  <!-- Page Header -->
  <section class="relative pt-32 pb-20 bg-navy overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-gold rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold font-semibold text-sm tracking-widest uppercase" data-i18n="booking.header.tag">Book Your Ride</span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white mt-3 mb-6" data-i18n="booking.header.title">Book Taxi Online</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto" data-i18n="booking.header.subtitle">
        Fill in the form below and we'll confirm your booking within minutes. No advance payment required.
      </p>
    </div>
  </section>

  <!-- Booking Form -->
  <section class="py-24 bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-3xl shadow-xl p-8 sm:p-12">
        <div class="flex items-center gap-3 mb-8 pb-8 border-b border-gray-100">
          <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-navy" data-i18n="booking.form.title">Reservation Details</h2>
            <p class="text-gray-500 text-sm" data-i18n="booking.form.subtitle">All fields marked with * are required</p>
          </div>
        </div>

        <form id="booking-form" class="space-y-8">
          <!-- Trip Details -->
          <div>
            <h3 class="text-lg font-semibold text-navy mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-gold/10 rounded-lg flex items-center justify-center text-gold text-sm font-bold">1</span>
              <span data-i18n="booking.trip.title">Trip Details</span>
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="from" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.from.label">From *</label>
                <input type="text" id="from" name="from" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                  placeholder="e.g., Heraklion Airport" data-i18n-placeholder="booking.from.placeholder" />
              </div>
              <div>
                <label for="to" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.to.label">To *</label>
                <input type="text" id="to" name="to" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                  placeholder="e.g., Hotel Name, City" data-i18n-placeholder="booking.to.placeholder" />
              </div>
              <div>
                <label for="pickupDate" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.date.label">Select a Date *</label>
                <input type="date" id="pickupDate" name="pickupDate" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all" />
              </div>
              <div>
                <label for="pickupTime" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.time.label">Select a Time *</label>
                <input type="time" id="pickupTime" name="pickupTime" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all" />
              </div>
            </div>
          </div>

          <!-- Personal Information -->
          <div>
            <h3 class="text-lg font-semibold text-navy mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-gold/10 rounded-lg flex items-center justify-center text-gold text-sm font-bold">2</span>
              <span data-i18n="booking.personal.title">Personal Information</span>
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.name.label">Name *</label>
                <input type="text" id="firstName" name="firstName" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                  placeholder="John" data-i18n-placeholder="booking.name.placeholder" />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.lastName.label">Last Name *</label>
                <input type="text" id="lastName" name="lastName" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                  placeholder="Doe" data-i18n-placeholder="booking.lastName.placeholder" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.email.label">Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                  placeholder="john@example.com" data-i18n-placeholder="booking.email.placeholder" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.phone.label">Phone *</label>
                <input type="tel" id="phone" name="phone" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                  placeholder="+30 694 355 1122" data-i18n-placeholder="booking.phone.placeholder" />
              </div>
            </div>
          </div>

          <!-- Additional Services -->
          <div>
            <h3 class="text-lg font-semibold text-navy mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-gold/10 rounded-lg flex items-center justify-center text-gold text-sm font-bold">3</span>
              <span data-i18n="booking.additional.title">Additional Services</span>
            </h3>
            <div>
              <label for="additionalServices" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="booking.additional.label">Special requests, extra stops, child seats, luggage info, or anything else we should know</label>
              <textarea id="additionalServices" name="additionalServices" rows="4"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all resize-none"
                placeholder="e.g., I need a child seat, extra stop at the supermarket, 3 large suitcases..." data-i18n-placeholder="booking.additional.placeholder"></textarea>
            </div>
          </div>

          <!-- Submit -->
          <div class="pt-6 border-t border-gray-100">
            <div class="flex items-start gap-3 mb-6">
              <input type="checkbox" id="agreeTerms" name="agreeTerms" required
                class="w-5 h-5 rounded border-gray-300 text-gold focus:ring-gold/20 mt-0.5" />
              <label for="agreeTerms" class="text-sm text-gray-600" data-i18n-html="booking.consent">
                I agree to the <a href="/privacy-policy" class="text-gold hover:underline">Privacy Policy</a> and consent to LP Taxi Heraklion processing my personal data for this booking. *
              </label>
            </div>

            <button type="submit"
              class="w-full bg-gold hover:bg-gold-light text-navy font-semibold px-8 py-4 rounded-xl transition-all text-lg shadow-lg shadow-gold/20 flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span data-i18n="booking.submitBtn">Submit Booking Request</span>
            </button>

            <p class="text-center text-gray-500 text-sm mt-4" data-i18n="booking.noPayment">
              No advance payment required. You'll receive a confirmation email within minutes.
            </p>
          </div>
        </form>
      </div>

      <!-- Contact Alternative -->
      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-4" data-i18n="booking.phoneAlt">Prefer to book by phone?</p>
        <a href="tel:+306943551122" class="inline-flex items-center gap-2 text-gold font-semibold text-lg hover:text-gold-dark transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call +30 694 355 1122
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('booking-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thank you for your booking request! We will contact you shortly to confirm your reservation.');
  });
</script>
