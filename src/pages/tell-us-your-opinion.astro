---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tell Us Your Opinion | LP Taxi Heraklion">
  <!-- Page Header -->
  <section class="relative pt-32 pb-20 bg-navy overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-gold rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold font-semibold text-sm tracking-widest uppercase" data-i18n="feedback.header.tag">Your Feedback Matters</span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white mt-3 mb-6" data-i18n="feedback.header.title">Tell Us Your Opinion</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto" data-i18n="feedback.header.subtitle">
        We value your feedback. Help us improve our service by sharing your experience.
      </p>
    </div>
  </section>

  <!-- Feedback Form -->
  <section class="py-24 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-3xl shadow-xl p-8 sm:p-12">
        <div class="flex items-center gap-3 mb-8 pb-8 border-b border-gray-100">
          <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-navy" data-i18n="feedback.form.title">Share Your Experience</h2>
            <p class="text-gray-500 text-sm" data-i18n="feedback.form.subtitle">Your feedback helps us serve you better</p>
          </div>
        </div>

        <form id="feedback-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="feedbackName" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="feedback.name.label">Your Name *</label>
              <input type="text" id="feedbackName" name="feedbackName" required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                placeholder="John Doe" data-i18n-placeholder="feedback.name.placeholder" />
            </div>
            <div>
              <label for="feedbackEmail" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="feedback.email.label">Email *</label>
              <input type="email" id="feedbackEmail" name="feedbackEmail" required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all"
                placeholder="john@example.com" data-i18n-placeholder="feedback.email.placeholder" />
            </div>
          </div>

          <!-- Rating -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-3" data-i18n="feedback.rating.label">How would you rate your experience? *</label>
            <div class="flex gap-2" id="star-rating">
              {[1,2,3,4,5].map((star) => (
                <button type="button" data-rating={star}
                  class="star-btn w-12 h-12 rounded-xl border-2 border-gray-200 flex items-center justify-center hover:border-gold hover:bg-gold/10 transition-all">
                  <svg class="w-6 h-6 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                </button>
              ))}
            </div>
            <input type="hidden" id="ratingValue" name="rating" value="" />
          </div>

          <!-- Service Used -->
          <div>
            <label for="serviceUsed" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="feedback.service.label">Which service did you use?</label>
            <select id="serviceUsed" name="serviceUsed"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all bg-white">
              <option value="" data-i18n="feedback.service.default">Select a service</option>
              <option value="airport-transfer" data-i18n="feedback.service.airport">Airport Transfer</option>
              <option value="port-transfer" data-i18n="feedback.service.port">Port Transfer</option>
              <option value="hotel-transfer" data-i18n="feedback.service.hotel">Hotel Transfer</option>
              <option value="crete-cruise" data-i18n="feedback.service.cruise">Crete Cruise Tour</option>
              <option value="taste-heraklion" data-i18n="feedback.service.taste">Taste of Heraklion Tour</option>
              <option value="on-demand" data-i18n="feedback.service.onDemand">On Demand Ride</option>
            </select>
          </div>

          <!-- Feedback Text -->
          <div>
            <label for="feedbackText" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="feedback.text.label">Your Feedback *</label>
            <textarea id="feedbackText" name="feedbackText" rows="5" required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all resize-none"
              placeholder="Tell us about your experience with LP Taxi Heraklion..." data-i18n-placeholder="feedback.text.placeholder"></textarea>
          </div>

          <!-- Would Recommend -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-3" data-i18n="feedback.recommend.label">Would you recommend us to others?</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="recommend" value="yes" class="w-4 h-4 text-gold focus:ring-gold/20" />
                <span class="text-gray-700" data-i18n="feedback.recommend.yes">Yes, definitely!</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="recommend" value="maybe" class="w-4 h-4 text-gold focus:ring-gold/20" />
                <span class="text-gray-700" data-i18n="feedback.recommend.maybe">Maybe</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="recommend" value="no" class="w-4 h-4 text-gold focus:ring-gold/20" />
                <span class="text-gray-700" data-i18n="feedback.recommend.no">No</span>
              </label>
            </div>
          </div>

          <!-- Submit -->
          <button type="submit"
            class="w-full bg-gold hover:bg-gold-light text-navy font-semibold px-8 py-4 rounded-xl transition-all text-lg shadow-lg shadow-gold/20 flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
            <span data-i18n="feedback.submitBtn">Submit Feedback</span>
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const starBtns = document.querySelectorAll('.star-btn');
  const ratingInput = document.getElementById('ratingValue') as HTMLInputElement;
  let currentRating = 0;

  starBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const rating = Number(btn.getAttribute('data-rating'));
      currentRating = rating;
      if (ratingInput) ratingInput.value = String(rating);

      starBtns.forEach((b, i) => {
        const svg = b.querySelector('svg');
        if (svg) {
          if (i < rating) {
            svg.classList.remove('text-gray-300');
            svg.classList.add('text-gold');
            b.classList.add('border-gold', 'bg-gold/10');
            b.classList.remove('border-gray-200');
          } else {
            svg.classList.add('text-gray-300');
            svg.classList.remove('text-gold');
            b.classList.remove('border-gold', 'bg-gold/10');
            b.classList.add('border-gray-200');
          }
        }
      });
    });
  });

  const form = document.getElementById('feedback-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thank you for your feedback! We appreciate your time and will use your input to improve our service.');
  });
</script>
