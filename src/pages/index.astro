<script>
  const slides = document.querySelectorAll<HTMLImageElement>('[data-about-slide]');
  const dots = document.querySelectorAll<HTMLButtonElement>('.about-dot');
  const prevBtn = document.getElementById('about-prev');
  const nextBtn = document.getElementById('about-next');
  let current = 0;
  const total = slides.length;

  function goTo(index: number) {
    slides.forEach((s, i) => {
      s.style.opacity = i === index ? '1' : '0';
    });
    dots.forEach((d, i) => {
      d.className = i === index
        ? 'about-dot w-2.5 h-2.5 rounded-full bg-white transition-all'
        : 'about-dot w-2.5 h-2.5 rounded-full bg-white/50 transition-all';
    });
    current = index;
  }

  prevBtn?.addEventListener('click', () => goTo((current - 1 + total) % total));
  nextBtn?.addEventListener('click', () => goTo((current + 1) % total));
  dots.forEach(d => d.addEventListener('click', () => goTo(Number(d.dataset.dot))));

  setInterval(() => goTo((current + 1) % total), 5000);
</script>
