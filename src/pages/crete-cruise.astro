---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Crete Cruise Tours | LP Taxi Heraklion" description="Custom private taxi tours across Crete. Beaches, ruins, villages - half-day and full-day cruises with your own driver.">
  <!-- Page Header -->
  <section class="relative pt-32 pb-20 bg-navy overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-gold rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold font-semibold text-sm tracking-widest uppercase" data-i18n="cruise.header.tag">Explore Crete</span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white mt-3 mb-6" data-i18n="cruise.header.title">Crete Cruise</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto" data-i18n="cruise.header.subtitle">
        Discover the beauty of Crete with our custom road cruises. Tell us what you love, and we'll plan the perfect route.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-gold font-semibold text-sm tracking-widest uppercase" data-i18n="cruise.intro.tag">Custom Tours</span>
          <h2 class="font-display text-4xl font-bold text-navy mt-3 mb-6" data-i18n="cruise.intro.title">Your Crete, Your Way</h2>
          <p class="text-gray-600 text-lg mb-6 leading-relaxed" data-i18n="cruise.intro.text1">
            Our Crete Cruise is a fully customizable road tour of the island. Tell us what sites you'd like to see — from archaeological wonders and pristine beaches to charming villages and traditional restaurants — and we'll plan the right road cruise for you.
          </p>
          <p class="text-gray-600 mb-8 leading-relaxed" data-i18n="cruise.intro.text2">
            Our drivers are born and raised in Crete. They know the hidden gems, the scenic routes, and the best local spots that most tourists never find. Whether you're arriving by cruise ship and have a day to explore, or you want a multi-day adventure, we'll create an unforgettable experience.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/booktaxionline" class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-navy font-semibold px-6 py-3 rounded-xl transition-all">
              <span data-i18n="cruise.intro.bookBtn">Book a Crete Cruise</span>
            </a>
            <a href="tel:+306943551122" class="inline-flex items-center justify-center gap-2 text-navy font-semibold px-6 py-3 rounded-xl border-2 border-navy hover:bg-navy hover:text-white transition-all">
              <span data-i18n="cruise.intro.callBtn">Call to Discuss</span>
            </a>
          </div>
        </div>

        <!-- IMAGE: Replace with scenic Crete landscape -->
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-gradient-to-br from-navy to-navy-light">
            <div class="absolute inset-0 bg-[url('/images/LRM_EXPORT_19584388799415_20190127_204940514_edited.avif')] bg-cover bg-center"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Routes -->
  <section class="py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-gold font-semibold text-sm tracking-widest uppercase" data-i18n="cruise.routes.tag">Suggested Routes</span>
        <h2 class="font-display text-4xl font-bold text-navy mt-3 mb-6" data-i18n="cruise.routes.title">Popular Cruises</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg" data-i18n="cruise.routes.subtitle">
          Not sure where to go? Here are some of our most popular routes, or we can customize any tour to your preferences.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Knossos & History -->
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all">
          <!-- IMAGE: Replace with Knossos ruins photo -->
          <div class="h-64 bg-gradient-to-br from-navy to-navy-light relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('/images/knossos.avif')] bg-cover bg-center opacity-70 group-hover:scale-105 transition-transform duration-500"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent"></div>
            <div class="absolute bottom-4 left-6 right-6">
              <span class="inline-block bg-gold/90 text-navy text-xs font-bold px-3 py-1 rounded-full mb-2" data-i18n="cruise.routes.halfDay">Half Day</span>
              <h3 class="text-2xl font-bold text-white" data-i18n="cruise.routes.knossos.title">Knossos & Heraklion History Tour</h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4" data-i18n="cruise.routes.knossos.desc">Visit the legendary Palace of Knossos, explore the Archaeological Museum of Heraklion, and walk through the historic city center with its Venetian architecture, lion fountain, and old harbor.</p>
            <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                4-5 hours
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /></svg>
                Heraklion area
              </span>
            </div>
            <a href="/booktaxionline" class="inline-flex items-center gap-2 text-gold font-semibold hover:gap-3 transition-all">
              <span data-i18n="cruise.routes.bookTour">Book This Tour</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- South Coast Beaches -->
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all">
          <!-- IMAGE: Replace with south coast beach photo -->
          <div class="h-64 bg-gradient-to-br from-navy to-navy-light relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('/images/IMG_3579.avif')] bg-cover bg-center opacity-70 group-hover:scale-105 transition-transform duration-500"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent"></div>
            <div class="absolute bottom-4 left-6 right-6">
              <span class="inline-block bg-gold/90 text-navy text-xs font-bold px-3 py-1 rounded-full mb-2" data-i18n="cruise.routes.fullDay">Full Day</span>
              <h3 class="text-2xl font-bold text-white" data-i18n="cruise.routes.beach.title">South Coast Beach Adventure</h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4" data-i18n="cruise.routes.beach.desc">Escape to the stunning south coast of Crete. Visit the famous Matala beach with its hippie caves, the palm forest of Preveli, and the charming seaside village of Plakias.</p>
            <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                7-8 hours
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /></svg>
                South Crete
              </span>
            </div>
            <a href="/booktaxionline" class="inline-flex items-center gap-2 text-gold font-semibold hover:gap-3 transition-all">
              <span data-i18n="cruise.routes.bookTour">Book This Tour</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- East Crete -->
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all">
          <!-- IMAGE: Replace with Spinalonga or Elounda photo -->
          <div class="h-64 bg-gradient-to-br from-navy to-navy-light relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('/images/IMG_1279.avif')] bg-cover bg-center opacity-70 group-hover:scale-105 transition-transform duration-500"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent"></div>
            <div class="absolute bottom-4 left-6 right-6">
              <span class="inline-block bg-gold/90 text-navy text-xs font-bold px-3 py-1 rounded-full mb-2" data-i18n="cruise.routes.fullDay">Full Day</span>
              <h3 class="text-2xl font-bold text-white" data-i18n="cruise.routes.east.title">Agios Nikolaos & Elounda</h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4" data-i18n="cruise.routes.east.desc">Discover the cosmopolitan Agios Nikolaos with its picturesque Voulismeni Lake, visit luxurious Elounda, and take a boat to the historic island of Spinalonga.</p>
            <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                6-7 hours
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /></svg>
                East Crete
              </span>
            </div>
            <a href="/booktaxionline" class="inline-flex items-center gap-2 text-gold font-semibold hover:gap-3 transition-all">
              <span data-i18n="cruise.routes.bookTour">Book This Tour</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- West Crete -->
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all">
          <!-- IMAGE: Replace with Chania/Rethymno photo -->
          <div class="h-64 bg-gradient-to-br from-navy to-navy-light relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('/images/IMG_1280.avif')] bg-cover bg-center opacity-70 group-hover:scale-105 transition-transform duration-500"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-navy/80 to-transparent"></div>
            <div class="absolute bottom-4 left-6 right-6">
              <span class="inline-block bg-gold/90 text-navy text-xs font-bold px-3 py-1 rounded-full mb-2" data-i18n="cruise.routes.fullDay">Full Day</span>
              <h3 class="text-2xl font-bold text-white" data-i18n="cruise.routes.west.title">Rethymno & Chania Explorer</h3>
            </div>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4" data-i18n="cruise.routes.west.desc">Journey west to the enchanting cities of Rethymno and Chania. Explore Venetian harbors, Ottoman architecture, winding old town streets, and stunning coastal views.</p>
            <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                8-10 hours
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /></svg>
                West Crete
              </span>
            </div>
            <a href="/booktaxionline" class="inline-flex items-center gap-2 text-gold font-semibold hover:gap-3 transition-all">
              <span data-i18n="cruise.routes.bookTour">Book This Tour</span>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-gold font-semibold text-sm tracking-widest uppercase" data-i18n="cruise.how.tag">Simple Process</span>
        <h2 class="font-display text-4xl font-bold text-navy mt-3 mb-6" data-i18n="cruise.how.title">How It Works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-gold rounded-2xl flex items-center justify-center mx-auto mb-6 text-navy font-bold text-2xl">1</div>
          <h3 class="text-lg font-bold text-navy mb-3" data-i18n="cruise.how.step1.title">Tell Us Your Interests</h3>
          <p class="text-gray-600" data-i18n="cruise.how.step1.desc">Let us know what you'd love to see — beaches, ruins, villages, food spots — and how many hours you have.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-gold rounded-2xl flex items-center justify-center mx-auto mb-6 text-navy font-bold text-2xl">2</div>
          <h3 class="text-lg font-bold text-navy mb-3" data-i18n="cruise.how.step2.title">We Plan Your Route</h3>
          <p class="text-gray-600" data-i18n="cruise.how.step2.desc">Our local experts design the perfect itinerary, combining your interests with hidden gems only locals know.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-gold rounded-2xl flex items-center justify-center mx-auto mb-6 text-navy font-bold text-2xl">3</div>
          <h3 class="text-lg font-bold text-navy mb-3" data-i18n="cruise.how.step3.title">Enjoy the Ride</h3>
          <p class="text-gray-600" data-i18n="cruise.how.step3.desc">Sit back in our luxury vehicle while your knowledgeable driver guides you through the best of Crete.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gold">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-navy mb-6" data-i18n="cruise.cta.title">Create Your Perfect Crete Adventure</h2>
      <p class="text-navy/70 text-lg mb-8" data-i18n="cruise.cta.subtitle">Contact us to discuss your ideal tour or book online now.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/booktaxionline" class="inline-flex items-center justify-center gap-2 bg-navy hover:bg-navy-light text-white font-semibold px-8 py-4 rounded-xl transition-all text-lg">
          <span data-i18n="cruise.cta.bookBtn">Book a Tour Online</span>
        </a>
        <a href="tel:+306943551122" class="inline-flex items-center justify-center gap-2 bg-white/20 hover:bg-white/30 text-navy font-semibold px-8 py-4 rounded-xl transition-all text-lg border-2 border-navy/20">
          <span data-i18n="cruise.cta.callBtn">Call to Discuss</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
