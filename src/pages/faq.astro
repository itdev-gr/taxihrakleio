---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FAQ | LP Taxi Heraklion - Frequently Asked Questions">
  <!-- Page Header -->
  <section class="relative pt-32 pb-20 bg-navy overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-gold rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mt-3 mb-6" data-i18n="faq.header.title">Frequently Asked Questions</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto" data-i18n="faq.header.subtitle">
        Everything you need to know about our taxi services in Heraklion, Crete.
      </p>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="py-24 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-4">

        <!-- FAQ 1 -->
        <div class="faq-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between p-6 text-left">
            <h2 class="font-display text-lg font-bold text-navy pr-4" data-i18n="faq.q1.title">How much does a taxi from Heraklion Airport to the city center cost?</h2>
            <svg class="faq-icon w-6 h-6 text-gold shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <p class="text-gray-600 leading-relaxed" data-i18n="faq.q1.answer">The taxi fare from Heraklion International Airport (HER) to the city center is a fixed rate. The airport is only about 5 kilometers from the center, and the ride takes approximately 10–15 minutes. With LP Taxi, you get transparent fixed pricing with no hidden charges — the price you see when booking is exactly what you pay.</p>
          </div>
        </div>

        <!-- FAQ 2 -->
        <div class="faq-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between p-6 text-left">
            <h2 class="font-display text-lg font-bold text-navy pr-4" data-i18n="faq.q2.title">Can I book a taxi in Heraklion in advance?</h2>
            <svg class="faq-icon w-6 h-6 text-gold shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <p class="text-gray-600 leading-relaxed" data-i18n="faq.q2.answer">Yes! We highly recommend booking your taxi in advance, especially for airport and port transfers. You can easily book online through our website 24/7, or call us directly. Pre-booking ensures a driver is waiting for you on arrival — no queues, no waiting, no stress.</p>
          </div>
        </div>

        <!-- FAQ 3 -->
        <div class="faq-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between p-6 text-left">
            <h2 class="font-display text-lg font-bold text-navy pr-4" data-i18n="faq.q3.title">Are taxis available 24 hours in Heraklion?</h2>
            <svg class="faq-icon w-6 h-6 text-gold shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <p class="text-gray-600 leading-relaxed" data-i18n="faq.q3.answer">Absolutely. LP Taxi Heraklion operates 24 hours a day, 7 days a week, 365 days a year. Whether you have an early morning flight, a late-night ferry arrival, or need a ride at any hour, we are always available. Just book online or call us anytime.</p>
          </div>
        </div>

        <!-- FAQ 4 -->
        <div class="faq-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between p-6 text-left">
            <h2 class="font-display text-lg font-bold text-navy pr-4" data-i18n="faq.q4.title">How do I get from Heraklion Airport to my hotel?</h2>
            <svg class="faq-icon w-6 h-6 text-gold shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <p class="text-gray-600 leading-relaxed" data-i18n="faq.q4.answer">The easiest and most comfortable way is to book a private taxi transfer. With LP Taxi, your driver will meet you at the arrivals hall with a name sign, help with your luggage, and take you directly to your hotel anywhere in Crete — whether it's in Heraklion city, Hersonissos, Malia, Agios Nikolaos, Rethymno, or beyond.</p>
          </div>
        </div>

        <!-- FAQ 5 -->
        <div class="faq-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between p-6 text-left">
            <h2 class="font-display text-lg font-bold text-navy pr-4" data-i18n="faq.q5.title">Is it safe to take a taxi in Crete?</h2>
            <svg class="faq-icon w-6 h-6 text-gold shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <p class="text-gray-600 leading-relaxed" data-i18n="faq.q5.answer">Yes, taking a taxi in Crete is very safe. LP Taxi Heraklion uses fully licensed, professional drivers with years of experience. Our modern, air-conditioned Mercedes vehicles are well-maintained and insured. We are a trusted, locally-operated service with hundreds of satisfied customers and 5-star ratings.</p>
          </div>
        </div>

        <!-- FAQ 6 -->
        <div class="faq-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between p-6 text-left">
            <h2 class="font-display text-lg font-bold text-navy pr-4" data-i18n="faq.q6.title">How much does a taxi from Heraklion to Hersonissos or Malia cost?</h2>
            <svg class="faq-icon w-6 h-6 text-gold shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <p class="text-gray-600 leading-relaxed" data-i18n="faq.q6.answer">Taxi fares from Heraklion to popular destinations like Hersonissos and Malia are offered at competitive fixed prices. With LP Taxi, there are no surprises — you'll know the exact fare before your trip. Contact us or use our online booking form to get an instant quote for your specific route.</p>
          </div>
        </div>

        <!-- FAQ 7 -->
        <div class="faq-item bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between p-6 text-left">
            <h2 class="font-display text-lg font-bold text-navy pr-4" data-i18n="faq.q7.title">Do you offer private tours and day trips from Heraklion?</h2>
            <svg class="faq-icon w-6 h-6 text-gold shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-6">
            <p class="text-gray-600 leading-relaxed" data-i18n="faq.q7.answer">Yes! Besides transfers, we offer custom private tours and day trips across Crete. Explore Knossos Palace, the old town of Rethymno, Elounda, Spinalonga, and many more destinations. Our drivers are knowledgeable locals who can guide you to hidden gems and the best spots on the island.</p>
          </div>
        </div>

      </div>

      <!-- CTA -->
      <div class="text-center mt-16">
        <p class="text-gray-600 text-lg mb-6" data-i18n="faq.cta.text">Still have questions? We're here to help!</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/booktaxionline" class="inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-navy font-semibold px-8 py-4 rounded-xl transition-all text-lg shadow-lg shadow-gold/20">
            <span data-i18n="faq.cta.bookBtn">Book Your Ride</span>
          </a>
          <a href="tel:+306943551122" class="inline-flex items-center justify-center gap-2 bg-navy hover:bg-navy-light text-white font-semibold px-8 py-4 rounded-xl transition-all text-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>+30 694 355 1122</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const answer = item.querySelector('.faq-answer')!;
      const icon = item.querySelector('.faq-icon')!;

      const isOpen = !answer.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-180'));

      // Toggle current
      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.classList.add('rotate-180');
      }
    });
  });
</script>
